<UserControl x:Class="Hat.Views.Controls.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundSecondaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- New conversation button -->
            <RowDefinition Height="Auto" /> <!-- Search -->
            <RowDefinition Height="*" />    <!-- Conversation list -->
            <RowDefinition Height="Auto" /> <!-- Settings footer -->
        </Grid.RowDefinitions>

        <!-- New Conversation -->
        <Button Grid.Row="0" Content="+ Nova Conversa"
                FontSize="12" FontWeight="Medium"
                Margin="8,8" Padding="10,8"
                HorizontalContentAlignment="Left"
                Click="NewConversation_Click"
                Foreground="{DynamicResource TextPrimaryBrush}"
                Background="{DynamicResource SurfaceHoverBrush}"
                BorderThickness="0" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}" Cursor="Hand">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Search -->
        <TextBox Grid.Row="1" x:Name="SearchBox"
                 FontSize="11" Padding="8,6"
                 Margin="8,0,8,8"
                 Background="{DynamicResource InputBackgroundBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 BorderThickness="0.5"
                 TextChanged="SearchBox_TextChanged"
                 Style="{StaticResource GlassTextBox}" />

        <!-- Conversation List -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ConversationList" Margin="4,0" />
        </ScrollViewer>

        <!-- Footer: Settings -->
        <Border Grid.Row="3" Padding="8,6"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Width="28" Height="28" HorizontalAlignment="Left"
                        Click="Settings_Click"
                        ToolTip="Configuracoes"
                        Style="{StaticResource GlassIconButton}" />
                <TextBlock Text="v1.0.0" FontSize="9"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
