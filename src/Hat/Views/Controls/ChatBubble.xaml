<UserControl x:Class="Hat.Views.Controls.ChatBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Hat.Views.Controls"
             xmlns:converters="clr-namespace:Hat.Converters"
             MouseEnter="OnMouseEnter" MouseLeave="OnMouseLeave">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="16,0">
        <!-- USER MESSAGE -->
        <Grid x:Name="UserPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60" />  <!-- Spacer -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right" MaxWidth="500">
                <!-- Screen analysis badge -->
                <Border x:Name="UserSourceBadge" Visibility="Collapsed"
                        HorizontalAlignment="Right" Margin="0,0,0,4"
                        Background="{DynamicResource AccentSubtleBrush}"
                        CornerRadius="10" Padding="8,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Foreground="{DynamicResource AccentPrimaryBrush}" Margin="0,0,4,0" />
                        <TextBlock Text="Analise de Tela" FontSize="10" FontWeight="Medium"
                                   Foreground="{DynamicResource AccentPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Attachments -->
                <ItemsControl x:Name="UserAttachments" Margin="0,0,0,4" />

                <!-- Message bubble -->
                <Border CornerRadius="14" Padding="14,10"
                        Background="{DynamicResource AccentSubtleBrush}"
                        BorderBrush="{DynamicResource AccentPrimaryBrush}"
                        BorderThickness="0.5" Opacity="0.95">
                    <TextBlock x:Name="UserText" TextWrapping="Wrap" FontSize="12.5"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </Border>

                <!-- Hover: copy + timestamp -->
                <StackPanel x:Name="UserHoverActions" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,4,0,0"
                            Visibility="Collapsed">
                    <TextBlock x:Name="UserTimestamp" FontSize="9"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Opacity="0.8" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button x:Name="UserCopyBtn" Click="CopyMessage_Click"
                            Style="{DynamicResource GlassIconButton}"
                            Width="Auto" Height="Auto" Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="UserCopyIcon" Text="&#xE8C8;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="9"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ASSISTANT MESSAGE -->
        <Grid x:Name="AssistantPanel" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Avatar -->
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />   <!-- Spacer -->
            </Grid.ColumnDefinitions>

            <!-- Avatar -->
            <Border x:Name="AvatarBorder" Grid.Column="0" Width="30" Height="30"
                    CornerRadius="15" VerticalAlignment="Top" Margin="0,2,10,0"
                    Background="{DynamicResource GlassSurfaceBrush}">
                <TextBlock Text="🎩" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                <Border.Effect>
                    <DropShadowEffect Color="{DynamicResource AccentPrimaryColor}"
                                      BlurRadius="5" Opacity="0.3" ShadowDepth="0" />
                </Border.Effect>
            </Border>

            <StackPanel Grid.Column="1" MaxWidth="480">
                <!-- Typing dots (while waiting for first token) -->
                <controls:TypingDots x:Name="StreamingDots" Visibility="Collapsed"
                                     Margin="0,4,0,4" />

                <!-- Markdown content (non-streaming) -->
                <controls:MarkdownViewer x:Name="MarkdownContent" Visibility="Collapsed"
                                         Margin="0,4,0,4" />

                <!-- Plain text (while streaming — avoids markdown flicker) -->
                <TextBlock x:Name="StreamingText" Visibility="Collapsed"
                           TextWrapping="Wrap" FontSize="12.5"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="0,4,0,4" />

                <!-- Hover: copy + timestamp -->
                <StackPanel x:Name="AssistantHoverActions" Orientation="Horizontal"
                            Margin="0,4,0,0" Visibility="Collapsed">
                    <TextBlock x:Name="AssistantTimestamp" FontSize="9"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Opacity="0.8" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Button x:Name="AssistantCopyBtn" Click="CopyMessage_Click"
                            Style="{DynamicResource GlassIconButton}"
                            Width="Auto" Height="Auto" Padding="6,3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="AssistantCopyIcon" Text="&#xE8C8;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="9"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
