<Window x:Class="Hat.Views.Windows.AnalysisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hat - Analise de Tela"
        Width="1000" Height="700"
        MinWidth="700" MinHeight="500"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Border CornerRadius="12" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{DynamicResource BackgroundSecondaryBrush}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Analise de Tela" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                Width="28" Height="28" Click="Close_Click"
                                Style="{StaticResource WindowCloseButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: Split panel -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.45*" /> <!-- Analysis result -->
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="0.55*" /> <!-- Screenshot -->
                </Grid.ColumnDefinitions>

                <!-- Left: Analysis Result -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" Padding="16" VerticalScrollBarVisibility="Auto">
                        <!-- Analysis text (markdown rendered) -->
                        <TextBlock x:Name="AnalysisText"
                                   Text="{Binding AnalysisResult}"
                                   TextWrapping="Wrap" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </ScrollViewer>

                    <!-- Follow-up input -->
                    <Border Grid.Row="1" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" x:Name="FollowUpBox"
                                     FontSize="12" Padding="10,8"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="0.5"
                                     Style="{StaticResource GlassTextBox}" />

                            <Button Grid.Column="1" Content="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                    Width="28" Height="28" Margin="6,0"
                                    Click="FollowUp_Click"
                                    Style="{StaticResource GlassIconButton}" />

                            <Button Grid.Column="2" Content="Transferir para Chat"
                                    FontSize="11" Padding="12,6"
                                    Click="TransferToChat_Click"
                                    Style="{StaticResource AccentButton}" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Divider -->
                <Rectangle Grid.Column="1" Fill="{DynamicResource BorderBrush}" />

                <!-- Right: Screenshot Preview -->
                <Border Grid.Column="2" Padding="16">
                    <Image x:Name="ScreenshotPreview"
                           Stretch="Uniform" StretchDirection="DownOnly" />
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
