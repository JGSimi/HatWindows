<Window x:Class="Hat.Views.Windows.QuickInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hat - Quick Input"
        Width="680" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <Border CornerRadius="16" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0.5"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.25" ShadowDepth="10" />
        </Border.Effect>

        <StackPanel>
            <!-- Attachment preview -->
            <ScrollViewer x:Name="AttachmentBar" Visibility="Collapsed"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Height="44" Margin="0,0,0,8">
                <StackPanel x:Name="AttachmentPreviews" Orientation="Horizontal" />
            </ScrollViewer>

            <!-- Input field + buttons -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Attach -->
                    <ColumnDefinition Width="*" />    <!-- Input -->
                    <ColumnDefinition Width="Auto" /> <!-- Send -->
                </Grid.ColumnDefinitions>

                <!-- File picker button -->
                <Button Grid.Column="0" Width="36" Height="36" Margin="0,0,8,0"
                        Click="AttachFile_Click" ToolTip="Anexar arquivo"
                        Style="{DynamicResource GlassIconButton}">
                    <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                </Button>

                <TextBox Grid.Column="1" x:Name="QuickInputBox"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="False" TextWrapping="Wrap"
                         MaxHeight="120" FontSize="14"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         Background="{DynamicResource InputBackgroundBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         BorderThickness="0.5" Padding="16,12"
                         KeyDown="QuickInputBox_KeyDown"
                         AllowDrop="True" PreviewDragOver="Input_DragOver" Drop="Input_Drop"
                         Style="{DynamicResource GlassTextBox}" />

                <Button Grid.Column="2" Width="36" Height="36" Margin="10,0,0,0"
                        Click="Send_Click"
                        Style="{DynamicResource AccentIconButton}">
                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                </Button>
            </Grid>

            <!-- Recent prompts -->
            <StackPanel x:Name="RecentPromptsPanel" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,10,0,0" />

            <!-- Hint text -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="Return para enviar" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="  |  " FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <TextBlock Text="Esc para fechar" FontSize="10"
                           Foreground="{DynamicResource TextMutedBrush}" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
