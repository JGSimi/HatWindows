<Window x:Class="Hat.Views.Windows.TrayPopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Hat.Views.Controls"
        xmlns:converters="clr-namespace:Hat.Converters"
        Title="Hat"
        Width="380" Height="480"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="16" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource GlassBorderSubtleBrush}" BorderThickness="0.5"
            x:Name="MainBorder">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="8" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Settings panel (togglable) -->
                <RowDefinition Height="*" />    <!-- Chat messages -->
                <RowDefinition Height="Auto" /> <!-- Attachment preview -->
                <RowDefinition Height="Auto" /> <!-- Input -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,12,16,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Vertical">
                        <TextBlock x:Name="GreetingText" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Border Background="{DynamicResource SurfaceTertiaryBrush}"
                                    CornerRadius="5" Padding="8,3" Cursor="Hand"
                                    MouseLeftButtonUp="ToggleSettings_Click">
                                <TextBlock x:Name="ModelTag" FontSize="10" FontWeight="Medium"
                                           Foreground="{DynamicResource TextMutedBrush}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                        <!-- Settings gear -->
                        <Button Content="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Width="28" Height="28" Click="ToggleSettings_Click"
                                ToolTip="Configuracoes"
                                Style="{DynamicResource GlassIconButton}" />
                        <!-- Expand -->
                        <Button Content="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Width="28" Height="28" Click="Expand_Click"
                                ToolTip="Abrir janela principal"
                                Style="{DynamicResource GlassIconButton}" />
                        <!-- Close -->
                        <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Width="28" Height="28" Click="Close_Click"
                                ToolTip="Fechar"
                                Style="{DynamicResource GlassIconButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Inline Settings Panel -->
            <Border Grid.Row="1" x:Name="SettingsPanelBorder" Visibility="Collapsed"
                    Padding="12,0,12,8">
                <controls:SettingsPanel x:Name="InlineSettings" />
            </Border>

            <!-- Chat Messages -->
            <Grid Grid.Row="2">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="4,0"
                              x:Name="ChatScrollViewer"
                              ScrollChanged="ChatScroll_Changed">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:ChatBubble Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24"
                            Background="{DynamicResource SurfaceTertiaryBrush}"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="🎩" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Hat" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock FontSize="10" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"
                               TextAlignment="Center">
                        <Run Text="Ctrl+Shift+X" FontWeight="Medium" /> <Run Text="Clipboard" /><LineBreak />
                        <Run Text="Ctrl+Shift+Z" FontWeight="Medium" /> <Run Text="Captura de tela" /><LineBreak />
                        <Run Text="Ctrl+Shift+Space" FontWeight="Medium" /> <Run Text="Quick Input" />
                    </TextBlock>
                </StackPanel>

                <!-- Scroll-to-bottom button -->
                <Button x:Name="ScrollToBottomBtn" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,8" Click="ScrollToBottom_Click"
                        Width="28" Height="28" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{DynamicResource GlassSurfaceBrush}"
                                    CornerRadius="14"
                                    BorderBrush="{DynamicResource GlassBorderSubtleBrush}"
                                    BorderThickness="0.5">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.06" ShadowDepth="2" />
                                </Border.Effect>
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Attachment preview bar -->
            <ScrollViewer Grid.Row="3" x:Name="AttachmentBar" Visibility="Collapsed"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Height="52" Padding="12,4">
                <StackPanel x:Name="AttachmentPreviews" Orientation="Horizontal" />
            </ScrollViewer>

            <!-- Input Area -->
            <Border Grid.Row="4" Padding="12,4,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Screenshot btn -->
                        <ColumnDefinition Width="*" />    <!-- Input -->
                        <ColumnDefinition Width="Auto" /> <!-- Send/Stop -->
                    </Grid.ColumnDefinitions>

                    <!-- Screenshot button -->
                    <Button Grid.Column="0" Width="28" Height="28" Margin="0,0,6,0"
                            Click="Screenshot_Click" ToolTip="Capturar tela"
                            Style="{DynamicResource GlassIconButton}">
                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Button>

                    <TextBox Grid.Column="1" x:Name="InputBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="False" TextWrapping="Wrap"
                             MaxHeight="80" FontSize="12.5"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Background="{DynamicResource InputBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             BorderThickness="0.5" Padding="12,9"
                             KeyDown="InputBox_KeyDown"
                             AllowDrop="True" PreviewDragOver="Input_DragOver" Drop="Input_Drop"
                             Style="{DynamicResource GlassTextBox}" />

                    <!-- Send / Stop button -->
                    <Button Grid.Column="2" x:Name="SendButton"
                            Width="32" Height="32" Margin="8,0,0,0"
                            Click="Send_Click"
                            Style="{DynamicResource AccentIconButton}">
                        <TextBlock x:Name="SendIcon" Text="&#xE724;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="14" />
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
