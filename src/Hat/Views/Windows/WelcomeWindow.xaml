<Window x:Class="Hat.Views.Windows.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bem-vindo ao Hat"
        Width="520" Height="550"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Border CornerRadius="20" Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource GlassBorderBrush}" BorderThickness="0.5"
            Padding="32">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.2" ShadowDepth="10" />
        </Border.Effect>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Hat icon -->
            <Border Width="80" Height="80" CornerRadius="40"
                    Background="{DynamicResource AccentSubtleBrush}"
                    HorizontalAlignment="Center" Margin="0,0,0,24">
                <TextBlock Text="🎩" FontSize="36"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- Title -->
            <TextBlock Text="Bem-vindo ao Hat" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />

            <TextBlock Text="Seu assistente de IA na bandeja do sistema"
                       FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,0,0,32" />

            <!-- Features -->
            <StackPanel Margin="0,0,0,32">
                <!-- Feature 1 -->
                <Border Margin="0,0,0,12" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{DynamicResource AccentSubtleBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Sempre Pronto" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Clique no icone na bandeja do sistema"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Feature 2 -->
                <Border Margin="0,0,0,12" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{DynamicResource AccentSubtleBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Analise de Tela Inteligente" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Ctrl+Shift+Z para capturar e analisar"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Feature 3 -->
                <Border Margin="0,0,0,12" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="8"
                                Background="{DynamicResource AccentSubtleBrush}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource AccentPrimaryBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Analise de Clipboard" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Ctrl+Shift+X para processar o conteudo"
                                       FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Start button -->
            <Button Content="Comecar a Usar" FontSize="14" FontWeight="SemiBold"
                    Padding="32,12" HorizontalAlignment="Center"
                    Click="Start_Click" Cursor="Hand"
                    Foreground="White"
                    Background="{DynamicResource AccentPrimaryBrush}"
                    BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Version -->
            <TextBlock Text="v1.0.0" FontSize="10"
                       Foreground="{DynamicResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,16,0,0" />
        </StackPanel>
    </Border>
</Window>
